# ============================================
# FLAME STACK BUSINESS SUITE — Environment Variables
# ============================================
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file — it contains secret keys.
#
# Don't have these yet? The app works with demo data out of the box.
# Set these up when you're ready to connect real services.

# --- Supabase (Database + Auth) ---
# Get these from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Stripe (Payments) ---
# Get this from: dashboard.stripe.com → Developers → API keys
# Use the PUBLISHABLE key (starts with pk_), NOT the secret key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# --- AI Features (Claude API via Edge Function) ---
# This URL points to your Supabase Edge Function that calls the Claude API
# Set this up in Week 7 when we build the AI Assistant module
VITE_AI_FUNCTION_URL=
